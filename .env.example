# --- Telegram Settings ---
TG_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
DOMAIN=your-app-name.vercel.app
# Private channel ID for internal logs (bot must be admin in the channel)
LOG_CHAT_ID=YOUR_PRIVATE_CHANNEL_ID_HERE

# --- Weatherbit Settings ---
WEATHERBIT_KEY=YOUR_WEATHERBIT_API_KEY_HERE

# --- Database ---
# Replace with your connection string from MongoDB Atlas
# Example format: mongodb+srv://<db_user>:<db_password>@cluster.mongodb.net/<db_name>
MONGO_URI=mongodb+srv://REPLACE_WITH_USER:REPLACE_WITH_PASSWORD@your-cluster.mongodb.net/weather_sentinel

# --- Vercel Secrets ---
# CRON_SECRET: A random long string for security.
# Used for: 
# 1. Authenticating scheduled GitHub Actions (cron jobs).
# 2. Hashing user IDs in dashboard URLs (cryptographic signature).
# Example: CRON_SECRET=My_Super_Secret_Key_For_Parasol_2026
CRON_SECRET=YOUR_CUSTOM_SECRET_STRING_HERE
