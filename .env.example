# --- Telegram Settings ---
TG_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
DOMAIN=your-app-name.vercel.app

# --- Weatherbit Settings ---
WEATHERBIT_KEY=YOUR_WEATHERBIT_API_KEY_HERE

# --- Database ---
# Replace with your connection string from MongoDB Atlas
# Example format: mongodb+srv://<db_user>:<db_password>@cluster.mongodb.net/<db_name>
MONGO_URI=YOUR_MONGO_URI_HERE

# --- Vercel Secrets ---
# Random string for cron security (only if uncommented in code)
CRON_SECRET=YOUR_CUSTOM_SECRET_STRING_HERE
